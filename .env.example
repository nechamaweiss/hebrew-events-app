# מסד נתונים
# מקומי (SQLite): file:./dev.db
# פריסה בענן (Vercel + Neon) — הדבק את מחרוזת החיבור מ-Neon, למשל:
#   postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL="file:./dev.db"

# סוד ל-Vercel Cron (שליחת תזכורות אוטומטית). צור מחרוזת אקראית ארוכה.
CRON_SECRET="change-me-to-a-long-random-secret"

# מפתח לחתימת JWT — החלף למחרוזת אקראית ארוכה בסביבת ייצור
JWT_SECRET="change-me-to-a-long-random-secret-string"

# פרטי המנהל הראשוני (נטענים ב-seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin1234!"

# הגדרות SMTP לשליחת מיילים. אם ריק — המערכת עובדת ב"מצב הדמיה" (מדפיסה לקונסול ומתעדת בלוג)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# כתובת בסיס לקישורים במיילים (למשל שחזור סיסמה)
APP_URL="http://localhost:3000"
